<?xml version="1.0" encoding="utf-8"?>

<!-- 
	SidHUD strings
-->

<string_table>
	<string id="ui_mm_video_hud_sidslide">
		<text>SidHUD 設定</text>
	</string>



	<string id="ui_mm_video_hud_armorbar">
		<text>スーツの耐久値バーを表示</text>
	</string>
	<string id="ui_mm_video_hud_armorbar_desc">
		<text>スーツの耐久値を示すバーを表示します。</text>
	</string>
	<string id="ui_mm_video_hud_armortext">
		<text>スーツの耐久値（数値）</text>
	</string>
	<string id="ui_mm_video_hud_armortext_desc">
		<text>スーツの耐久値をシアン色の%数値で表示します。\nこの設定は、耐久値のバーが非表示になっている場合は適用されません。</text>
	</string>
	<string id="ui_mm_video_hud_weaponshow">
		<text>銃の耐久値バーを表示</text>
	</string>
	<string id="ui_mm_video_hud_weaponshow_desc">
		<text>現在装備している銃の耐久値を示すバーを表示します。</text>
	</string>
	<string id="ui_mm_video_hud_weapontext">
		<text>銃の耐久値（数値）</text>
	</string>
	<string id="ui_mm_video_hud_weapontext_desc">
		<text>銃の耐久値をオレンジ色の%数値で表示します。\nこの設定は、耐久値バーが無効になっている場合は適用されません。</text>
	</string>
	<string id="ui_mm_video_hud_weaponbarhide">
		<text>非装備時に耐久値バーを非表示</text>
	</string>
	<string id="ui_mm_video_hud_weaponbarhide_desc">
		<text>銃をしまっている間、銃の耐久値バーを非表示にします。\nこの設定は、耐久値のバーが非表示になっている場合は適用されません。</text>
	</string>
	<string id="ui_mm_video_hud_ammoshow">
		<text>総弾薬数を表示</text>
	</string>
	<string id="ui_mm_video_hud_ammoshow_desc">
		<text>現在所持している総弾薬数を表示します。</text>
	</string>
	<string id="ui_mm_video_hud_oldammoshow">
		<text>古い弾薬を表示</text>
	</string>
	<string id="ui_mm_video_hud_oldammoshow_desc">
		<text>必要に応じて古い弾薬の情報を表示します。</text>
	</string>
	<string id="ui_mm_video_hud_radhealthshow">
		<text>放射線被曝のバーを表示</text>
	</string>
	<string id="ui_mm_video_hud_radhealthshow_desc">
		<text>蓄積された放射線量を、体力バーの上に左から右へ重なるように表示します。</text>
	</string>
	<string id="ui_mm_video_hud_bleedingbarshow">
		<text>出血量のバーを表示</text>
	</string>
	<string id="ui_mm_video_hud_bleedingbarshow_desc">
		<text>現在の出血による損失量を、スタミナバーの上に左から右へ重なるように表示します。</text>
	</string>
	<string id="ui_mm_video_hud_healingbar">
		<text>回復予測のバーを表示</text>
	</string>
	<string id="ui_mm_video_hud_healingbar_desc">
		<text>回復アイテムを使用した際、最終的にどこまで体力が回復するかを体力バー上に予測表示します。</text>
	</string>
	
</string_table>