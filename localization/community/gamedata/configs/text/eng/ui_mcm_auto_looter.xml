<?xml version="1.0" encoding="utf-8"?>

<string_table>	
	<string id="ui_mcm_menu_auto_looter">
		<text>Auto Looter</text>
	</string>
	<string id="ui_mcm_auto_looter_base_description">
		<text>Auto Looterは、分解 → 部品／アタッチメントの取り外し → インベントリへの移動 → 削除の順に実行されます。\nスーツの分解や部品の自動回収を有効にしている場合、耐久値の条件を満たしている部品のみが取得されます。</text>
	</string>

	<string id="ui_mcm_auto_looter_looter_key_title">
		<text>キー設定</text>
	</string>
	<string id="ui_mcm_auto_looter_looter_key_description">
		<text>一部のアドオンはインベントリ画面での特定のキー入力をブロックする場合があります。左Altキーは通常ブロックされないため、下記のキー設定は変更しないことをおすすめします。</text>
	</string>
	<string id="ui_mcm_auto_looter_looter_key">
		<text>戦利品の自動回収 (Auto Looter)</text>
	</string>

	<string id="ui_mcm_auto_looter_remote_looting_title">
		<text>遠距離回収</text>
	</string>
	<string id="ui_mcm_auto_looter_remote_looting_description">
		<text>遠隔でアイテムを回収できる最大距離を設定します。0に設定するとこの機能は無効になります。\n注意: 死体やボックスのインベントリを開く際に追加スクリプトを実行するアドオンを使用している場合、遠距離回収は使用しないでください。GAMMA環境のプレイヤーは常に無効にすることを推奨します。</text>
	</string>
	<string id="ui_mcm_auto_looter_remote_looting_distance">
		<text>最大距離</text>
	</string>

	<string id="ui_mcm_auto_looter_proximity_looting_title">
		<text>実験的機能: 近距離回収</text>
	</string>
	<string id="ui_mcm_auto_looter_proximity_looting_description">
		<text>遠距離回収と似た動作をしますが、自動で一定間隔ごとに再実行され、指定範囲内のすべての回収可能な死体を処理します（インベントリボックスは除外され、スタッシュからの誤回収を防ぎます）。範囲を0に設定するとこの機能は無効になります。注意: 死体インベントリを開くときに追加スクリプトを実行するMODと併用する場合、近距離回収は使用しないでください。GAMMA環境のプレイヤーは常にオフにすることを推奨します。</text>
	</string>
	<string id="ui_mcm_auto_looter_proximity_looting_distance">
		<text>近距離回収の範囲</text>
	</string>
	<string id="ui_mcm_auto_looter_proximity_looting_refire_time">
		<text>近距離回収の実行間隔</text>
	</string>

	<string id="ui_mcm_auto_looter_disassemble_title">
		<text>自動分解の設定</text>
	</string>
	<string id="ui_mcm_auto_looter_disassemble_ammo">
		<text>弾薬の自動分解</text>
	</string>
	<string id="ui_mcm_auto_looter_disassemble_armor">
		<text>スーツ／ヘッドギアの自動分解</text>
	</string>
	<string id="ui_mcm_auto_looter_disassemble_armor_desc">
		<text>耐久値が50%以上、またはクラフトレシピで使用可能なスーツ部品のみが対象となります。</text>
	</string>
	<string id="ui_mcm_auto_looter_disassemble_weapon">
		<text>武器の自動分解</text>
	</string>
	<string id="ui_mcm_auto_looter_disassemble_misc_title">
		<text>その他アイテムの分解</text>
	</string>
	<string id="ui_mcm_auto_looter_disassemble_misc_description">
		<text>一部のジャンクアイテムは分解してもほとんど価値がなく、未分解のまま納品したほうがより高い報酬が得られる場合があります（例: メタル雑誌）。どのアイテムを分解対象にするか、以下で設定できます。なお、リストの最後にあるPDAは、スタッシュの情報を得られるストーカーのPDAのみを指します。</text>
	</string>

	<string id="ui_mcm_auto_looter_strip_title">
		<text>部品／アタッチメントの自動取り外し設定</text>
	</string>
	<string id="ui_mcm_auto_looter_strip_attachments">
		<text>アタッチメントの自動取り外し</text>
	</string>
	<string id="ui_mcm_auto_looter_strip_weapon">
		<text>銃部品の自動取り外し</text>
	</string>

	<string id="ui_mcm_auto_looter_loot_title">
		<text>自動回収の設定</text>
	</string>
	<string id="ui_mcm_auto_looter_loot_description">
		<text>どの種類のアイテムを（条件付きで）回収するかを設定します。スーツと武器は自動的に除外されます。以下に明記されていないアイテム（アップグレードキット、武器アタッチメント、修理アイテム、未分解のジャンクアイテムなど）は、自動的に取得されるように設計されています。</text>
	</string>
