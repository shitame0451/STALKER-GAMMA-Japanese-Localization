<?xml version="1.0" encoding="utf-8"?>
<string_table>

	<string id="ui_mcm_menu_magnifier_switch">
		<text>3DSS Magnifier Switch</text>
	</string>

	<string id="ui_mcm_magnifier_switch_title">
		<text>Magnifier Switch</text>
	</string>

	<string id="ui_mcm_magnifier_switch_use_mousewheel">
		<text>マウスホイールで切り替える（キー設定を無視）</text>
	</string>

	<string id="ui_mcm_magnifier_switch_use_mousewheel_desc">
		<text>マグニファイアの切り替えにマウスホイールを使用します。'mouse_wheel_invert_zoom' が有効な場合は、その設定に従って動作します。</text>
	</string>

	<string id="ui_mcm_magnifier_switch_mwheel_switch_ads_only">
		<text>ADS中のみマウスホイールで切り替える</text>
	</string>

	<string id="ui_mcm_magnifier_switch_mwheel_switch_ads_only_desc">
		<text>有効にすると、エイムしていない状態でのマウスホイールによるマグニファイア切り替えが無効になります。</text>
	</string>

	<string id="ui_mcm_magnifier_switch_mwheel_weapon_swap">
		<text>マウスホイールで武器を切り替える</text>
	</string>

	<string id="ui_mcm_magnifier_switch_mwheel_weapon_swap_desc">
		<text>この設定は、'mouse_wheel_change_weapon' コンソールコマンドやmodded exesの設定を簡易的に切り替えるショートカットとして機能します。</text>
	</string>

	<string id="ui_mcm_magnifier_switch_switch_bind">
		<text>マグニファイアの切り替え（3DSS Magnifier Switch）</text>
	</string>

	<string id="ui_mcm_magnifier_switch_switch_bind_desc">
		<text>この設定を「照準スタイルの切り替え」と同じキーに割り当てると、通常のキー動作とは異なる挙動となり、特定の条件（修飾キーなど）を満たさない状況でもマグニファイアの切り替えが可能になります。</text>
	</string>

	<string id="ui_mcm_magnifier_switch_keep_aim_toggle">
		<text>ADS（トグル）を維持</text>
	</string>

	<string id="ui_mcm_magnifier_switch_keep_aim_toggle_desc">
		<text>照準状態を維持したままマグニファイアを切り替えられます。（トグルエイムを使用している場合に有効です）</text>
	</string>

	<string id="ui_mcm_magnifier_switch_switch_sound">
		<text>効果音を鳴らす</text>
	</string>

	<string id="ui_mcm_magnifier_switch_switch_sound_desc">
		<text>マグニファイアの切り替え時に効果音を再生します。</text>
	</string>

	<string id="ui_mcm_magnifier_switch_debug">
		<text>デバッグログ</text>
	</string>

</string_table>
