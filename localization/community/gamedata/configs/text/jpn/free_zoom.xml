<?xml version="1.0" encoding="utf-8" ?>
<string_table>
	<string id="ui_mcm_menu_free_zoom">
		<text>Free Zoom</text>
	</string>
	<string id="ui_mcm_free_zoom_key_bind_toggle">
		<text>フリーズーム (Free Zoom)</text>
	</string>
	<string id="ui_mcm_free_zoom_key_bind_toggle_desc">
        <text>視界をズームインさせ、遠くの対象をより詳細に確認できます。この間、移動速度が低下します。</text>
	</string>
	<string id="ui_mcm_free_zoom_pistol_mult">
		<text>ピストル使用時の視野角倍率</text>
	</string>
	<string id="ui_mcm_free_zoom_pistol_mult_desc">
        <text>ピストル使用時に適用される視野角の倍率を設定します。値を大きくするとカメラからの距離が遠くなります。</text>
	</string>
	<string id="ui_mcm_free_zoom_ads_mult">
		<text>ADS時のズーム倍率</text>
	</string>
	<string id="ui_mcm_free_zoom_ads_mult_desc">
        <text>照準器を覗き込んだ際のズーム倍率を設定します。値を小さくするほど、ズームが強くなります。</text>
	</string>
	<string id="ui_mcm_free_zoom_free_zoom_mult">
		<text>フリーズーム時の倍率</text>
	</string>
	<string id="ui_mcm_free_zoom_free_zoom_mult_desc">
        <text>フリーズームキーを押した際のズーム倍率を設定します。値を小さくするほど、ズームが強くなります。</text>
	</string>
	<string id="ui_mcm_free_zoom_freezoom_toggleable">
		<text>フリーズームのトグル切り替え</text>
	</string>
</string_table>
