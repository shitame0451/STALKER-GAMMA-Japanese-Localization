<?xml version="1.0" encoding="UTF-8"?>

<string_table>

	<!-- Button -->
	<string id="ui_mcm_ssfx_module_ao">
		<text>アンビエントオクルージョン</text>
	</string>

	<!-- SSR Settings -->
	<string id="ui_mcm_ssfx_module_ao_title">
		<text>Ambient Occlusion Settings</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_quality_mcm">
		<text>品質</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_quality_mcm_desc">
		<text>[再起動が必要] アンビエントオクルージョンの描画に使用するサンプル数を設定します。「高」設定はパフォーマンスへの影響が大きくなります。 [ 2, 4, 8 ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_res_mcm">
		<text>解像度</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_res_mcm_desc">
		<text>アンビエントオクルージョンの描画解像度を設定します。</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_distance_mcm">
		<text>最大距離</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_distance_mcm_desc">
		<text>アンビエントオクルージョンが適用される最大距離を設定します。</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_blur_mcm">
		<text>ブラー</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_blur_mcm_desc">
		<text>アンビエントオクルージョンを滑らかにするブラーの強度を設定します。</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_radius_mcm">
		<text>アンビエントオクルージョンの距離</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_radius_mcm_desc">
		<text>ピクセル単位でのオクルージョンの最大距離を設定します。距離を増やす場合はアンビエントオクルージョンの強度も調整が必要になる場合があります。</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_max_occ_mcm">
		<text>アンビエントオクルージョンの最大値</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_max_occ_mcm_desc">
		<text>ピクセル単位でのアンビエントオクルージョンの最大値を設定します。 [ 0.0 = 完全な黒 ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_global_int_mcm">
		<text>アンビエントオクルージョンの強度（全体）</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_global_int_mcm_desc">
		<text>アンビエントオクルージョン全体の強度を設定します。 [ 1.0 = 100% ~ 0.5 = 50% ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_hud_int_mcm">
		<text>HUD要素に対する強度</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_hud_int_mcm_desc">
		<text>HUD要素（武器や腕など）に適用されるアンビエントオクルージョンの強度を設定します。この値は、全体のアンビエントオクルージョン強度に対する割合で適用されます。 [ 1.0 = 100% ~ 0.5 = 50% ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_flora_int_mcm">
		<text>植物に対する強度</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_flora_int_mcm_desc">
		<text>植物（草や木など）に適用されるアンビエントオクルージョンの強度を設定します。この値は、全体のアンビエントオクルージョン強度に対する割合で適用されます。 [ 1.0 = 100% ~ 0.5 = 50% ]</text>
	</string>

</string_table>