<?xml version="1.0" encoding="UTF-8"?>

<string_table>

	<!-- Button -->
	<string id="ui_mcm_ssfx_module_fog">
		<text>霧</text>
	</string>

	<!-- SSR Settings -->
	<string id="ui_mcm_ssfx_module_fog_title">
		<text>Fog Settings</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_height_mcm">
		<text>高さ</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_height_mcm_desc">
		<text>霧の高さを調整します。数値を高くするほど、霧がより自然で滑らかに表現されます。</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_density_mcm">
		<text>密度</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_density_mcm_desc">
		<text>霧の濃さを調整します。この設定の基本値は、現在の天候プリセットに依存します。</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_suncolor_mcm">
		<text>太陽光の色合い</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_suncolor_mcm_desc">
		<text>霧に太陽光の色合いがどの程度反映されるかを調整します。</text>
	</string>


	<string id="ui_mcm_ssfx_module_fog_scattering_mcm">
		<text>霧の散乱効果</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_scattering_mcm_desc">
		<text>霧の散乱効果（スキャッタリング）の量や強さを調整します。この効果を適用すると、霧が視覚的により濃く見えるようになります。</text>
	</string>


</string_table>