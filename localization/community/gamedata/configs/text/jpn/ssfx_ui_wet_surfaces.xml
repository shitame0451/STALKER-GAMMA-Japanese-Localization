<?xml version="1.0" encoding="UTF-8"?>

<string_table>

	<!-- Gloss Title -->
	<string id="ui_mcm_ssfx_module_wet_surf_title">
		<text>Wet Surfaces - Settings</text>
	</string>

	<!-- Gloss Settings -->
	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_buildup_speed_mcm">
		<text>水濡れ度 - 蓄積速度</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_buildup_speed_mcm_desc">
		<text>水たまりや湿った表面などが濡れていく速度を調整します。値を高くすると、より速く水濡れ度が蓄積されます。</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_dry_speed_mcm">
		<text>水濡れ度 - 乾燥速度</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_dry_speed_mcm_desc">
		<text>水たまりや湿った表面などが乾燥する速度を調整します。値を高くすると、より速く乾燥します。</text>
	</string>


	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_ripples_size_mcm">
		<text>雨の波紋の大きさ</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_ripples_size_mcm_desc">
		<text>雨が降った際にできる波紋の大きさを調整します。値を高くすると、波紋がより大きく表示されます。</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_ripples_speed_mcm">
		<text>雨の波紋の速度</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_ripples_speed_mcm_desc">
		<text>雨の波紋のアニメーション速度を調整します。（雨の強度によって基本速度が決まります）</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_ripples_min_speed_mcm">
		<text>雨の波紋の最小速度</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_ripples_min_speed_mcm_desc">
		<text>雨の波紋のアニメーションの最小速度を調整します。</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_ripples_intensity_mcm">
		<text>雨の波紋の強度</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_ripples_intensity_mcm_desc">
		<text>雨の波紋の視覚的な強度を調整します。</text>
	</string>


	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_waterfall_size_mcm">
		<text>流れる雨水の大きさ</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_waterfall_size_mcm_desc">
		<text>壁面などを伝って流れ落ちる雨水の表現の大きさを調整します。値を高くすると、より大きく表示されます。</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_waterfall_speed_mcm">
		<text>流れる雨水の速度</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_waterfall_speed_mcm_desc">
		<text>壁面などを伝って流れ落ちる雨水の表現の落下速度を調整します。（雨の強度によって基本速度が決まります）</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_waterfall_min_speed_mcm">
		<text>流れる雨水の最小速度</text>
	</string>
	
	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_waterfall_min_speed_mcm_desc">
		<text>壁面などを伝って流れ落ちる雨水の表現の最小速度を調整します。</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_waterfall_intensity_mcm">
		<text>流れる雨水の強度</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_waterfall_intensity_mcm_desc">
		<text>壁面などを伝って流れ落ちる雨水の表現の視覚的な強度を調整します。</text>
	</string>


	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_cover_res_mcm">
		<text>水濡れ表現の解像度</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_cover_res_mcm_desc">
		<text>水濡れ表現のレンダリング解像度を調整します。値を高くするとより鮮明になりますが、パフォーマンスに影響を与える場合があります。</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_cover_distance_mcm">
		<text>水濡れ表現の描画距離</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_wetness_ssfx_wet_surf_cover_distance_mcm_desc">
		<text>水濡れ表現のレンダリング距離を調整します。値を高くするとより遠くまで描画されますが、パフォーマンスに影響を与える場合があります。</text>
	</string>

