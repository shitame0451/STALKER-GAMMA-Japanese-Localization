<?xml version="1.0" encoding="utf-8"?>

<string_table>
			
	<string id="ui_mcm_safe_af_craft_title">
		<text>Safer Artefact Melting</text>
	</string>
	
	<string id="ui_mcm_safe_af_craft_empty_lead_absorb_enabled">
		<text>空の完全隔離容器による放射線吸収</text>
	</string>
	<string id="ui_mcm_safe_af_craft_empty_lead_absorb_enabled_desc">
		<text>インベントリに空の完全隔離容器と未収納のアーティファクトがある場合、空の隔離容器がアーティファクトから放出される放射線を吸収し、被曝を軽減します。\n携帯型作業台を使用している場合も有効です。</text>
	</string>
	
	<string id="ui_mcm_safe_af_craft_empty_lead_absorb_wshop_only">
		<text>作業台使用中のみ吸収（要アーティファクトメルター）</text>
	</string>
	<string id="ui_mcm_safe_af_craft_empty_lead_absorb_wshop_only_desc">
		<text>アーティファクトメルターを備えた作業台を開いている間のみ、空の完全隔離容器が放射線を吸収するようになります。</text>
	</string>
	
	<string id="ui_mcm_safe_af_craft_melter_absorb_enabled">
		<text>アーティファクトメルター使用時の全放射線吸収</text>
	</string>
	<string id="ui_mcm_safe_af_craft_melter_absorb_enabled_desc">
		<text>アーティファクトメルター使用中に発生するすべての放射線が吸収され、被曝を防ぎます。この際、空の完全隔離容器の有無は影響しません。</text>
	</string>

	
</string_table>
